<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom Sheet untuk tulis / edit review di CoffeeDetailActivity -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_white_rounded_top"
    android:padding="24dp">

    <!-- Handle bar -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="#DDDDDD"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <!-- Judul -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tulis Ulasan"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Nama coffee shop -->
    <TextView
        android:id="@+id/tv_review_sheet_shop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Coffee Shop"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"/>

    <!-- Label Nama Anda -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nama Anda"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Input Nama -->
    <EditText
        android:id="@+id/et_review_username"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Masukkan nama Anda..."
        android:padding="14dp"
        android:background="@drawable/bg_input_modern"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:inputType="textPersonName"
        android:maxLines="1"
        android:layout_marginBottom="16dp"/>

    <!-- Label rating -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Beri Rating"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <!-- 5 bintang interaktif -->
    <LinearLayout
        android:id="@+id/layout_star_selector"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <ImageView android:id="@+id/star_sel_1" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_star" android:tint="#E0E0E0" android:clickable="true"
            android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp" android:contentDescription="Bintang 1"/>
        <ImageView android:id="@+id/star_sel_2" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_star" android:tint="#E0E0E0" android:clickable="true"
            android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp" android:contentDescription="Bintang 2"/>
        <ImageView android:id="@+id/star_sel_3" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_star" android:tint="#E0E0E0" android:clickable="true"
            android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp" android:contentDescription="Bintang 3"/>
        <ImageView android:id="@+id/star_sel_4" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_star" android:tint="#E0E0E0" android:clickable="true"
            android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp" android:contentDescription="Bintang 4"/>
        <ImageView android:id="@+id/star_sel_5" android:layout_width="40dp" android:layout_height="40dp"
            android:src="@drawable/ic_star" android:tint="#E0E0E0" android:clickable="true"
            android:focusable="true" android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp" android:contentDescription="Bintang 5"/>
    </LinearLayout>

    <!-- Label komentar -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Komentar"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Input komentar -->
    <EditText
        android:id="@+id/et_review_comment"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:hint="Ceritakan pengalaman kamu di sini..."
        android:gravity="top|start"
        android:padding="14dp"
        android:background="@drawable/bg_input_modern"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:inputType="textMultiLine|textCapSentences"
        android:maxLines="5"
        android:layout_marginBottom="20dp"/>

    <!-- Tombol Kirim -->
    <Button
        android:id="@+id/btn_submit_review"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Kirim Ulasan"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/btn_pill_active"
        android:layout_marginBottom="12dp"/>

    <!-- Tombol Batal -->
    <Button
        android:id="@+id/btn_cancel_review"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Batal"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:background="@android:color/transparent"
        android:layout_marginBottom="8dp"/>

</LinearLayout>
