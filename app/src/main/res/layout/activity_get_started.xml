<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brown">

    <!-- Tall curved container -->
    <View
        android:id="@+id/card_background"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_cream_rounded_top"
        app:layout_constraintHeight_percent="0.82"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Country Flag Icon (Top Right) -->
    <LinearLayout
        android:id="@+id/flag_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="16dp"
        android:padding="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/flag_icon"
            android:layout_width="36dp"
            android:layout_height="24dp"
            android:layout_marginEnd="4dp"
            android:contentDescription="Pilih Negara"
            android:scaleType="fitCenter"
            android:src="@drawable/bendera_indo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▾"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Coffee Cup Icon -->
    <ImageView
        android:id="@+id/coffee_icon"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:contentDescription="Coffee Cup Icon"
        android:src="@drawable/logo_terbarucoffee"
        app:layout_constraintTop_toTopOf="@id/card_background"
        app:layout_constraintBottom_toTopOf="@id/location_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.4" />

    <!-- Location UI -->
    <LinearLayout
        android:id="@+id/location_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_get_started"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp">

        <ImageView
            android:id="@+id/location_icon"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginEnd="6dp"
            android:contentDescription="Lokasi"
            android:src="@android:drawable/ic_menu_mylocation"
            app:tint="@color/brown" />

        <TextView
            android:id="@+id/location_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mendeteksi lokasi..."
            android:textColor="@color/brown"
            android:textSize="14sp"
            android:fontFamily="serif" />
    </LinearLayout>

    <!-- Get Started Button -->
    <Button
        android:id="@+id/btn_get_started"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:layout_marginBottom="80dp"
        android:background="@drawable/bg_pill_brown"
        android:text="Get Started"
        android:textAllCaps="false"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>