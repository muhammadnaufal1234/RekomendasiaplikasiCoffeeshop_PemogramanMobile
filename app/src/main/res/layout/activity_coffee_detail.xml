                                android:textColor="@color/brown"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/tv_price_4"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
