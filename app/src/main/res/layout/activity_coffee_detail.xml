<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ====== HERO SECTION (Logo + Gradient Overlay + Back Button) ====== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <!-- Background logo / banner image -->
            <ImageView
                android:id="@+id/img_shop_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:adjustViewBounds="false"
                android:contentDescription="Shop Photo" />

            <!-- Gradient overlay gelap di bawah agar teks terbaca -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_hero_overlay" />

            <!-- Tombol Back (kiri atas) -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_margin="12dp"
                android:background="#33000000"
                android:layout_gravity="top|start"
                android:padding="0dp">

                <ImageView
                    android:id="@+id/btn_back_detail"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_back"
                    android:contentDescription="Back" />
            </FrameLayout>

            <!-- Nama toko di atas gambar (kiri bawah) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tv_shop_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kenangan Coffee"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:shadowColor="#88000000"
                    android:shadowRadius="4"
                    android:shadowDx="0"
                    android:shadowDy="1" />
            </LinearLayout>

        </FrameLayout>

        <!-- ====== DESKRIPSI CARD ====== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="-20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/cream">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tentang Kami"
                    android:textColor="@color/brown"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <View
                    android:layout_width="32dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    android:background="@color/brown" />

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Deskripsi"
                    android:textColor="@color/light_brown"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ====== SECTION TITLE: OUR MENU ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="4dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="4dp"
                android:layout_height="20dp"
                android:background="@color/brown" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Menu Kami"
                android:textColor="@color/brown"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- ====== FILTER PILLS ====== -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:scrollbars="none"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- ALL MENU PILL -->
                <Button
                    android:id="@+id/btn_all_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Semua Menu"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/btn_pill_active"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginEnd="8dp" />

                <!-- HOT COFFEE PILL -->
                <Button
                    android:id="@+id/btn_hot_coffee"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Hot Coffee"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="@color/brown"
                    android:background="@drawable/btn_pill_inactive"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginEnd="8dp" />

                <!-- ICE COFFEE PILL -->
                <Button
                    android:id="@+id/btn_ice_coffee"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Ice Coffee"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="@color/brown"
                    android:background="@drawable/btn_pill_inactive"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginEnd="8dp" />

                <!-- NON COFFEE PILL -->
                <Button
                    android:id="@+id/btn_non_coffee"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Non Coffee"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:textColor="@color/brown"
                    android:background="@drawable/btn_pill_inactive"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ====== MENU GRID ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Menu 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_menu_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/img_menu_1"
                            android:layout_width="match_parent"
                            android:layout_height="110dp"
                            android:scaleType="centerCrop"
                            android:src="@mipmap/ic_launcher"
                            android:contentDescription="Menu" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:id="@+id/tv_menu_1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Caramel Latte"
                                android:textColor="@color/brown"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:maxLines="2"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/tv_price_1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="15k"
                                android:textColor="@color/brown"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Menu 2 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_menu_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <ImageView
                            android:id="@+id/img_menu_2"
                            android:layout_width="match_parent"
                            android:layout_height="110dp"
                            android:scaleType="centerCrop"
