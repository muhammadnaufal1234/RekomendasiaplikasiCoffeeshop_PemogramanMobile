<?xml version="1.0" encoding="utf-8"?>
<!-- Layout untuk satu item di RecyclerView daftar favorit -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Logo Coffee Shop -->
        <ImageView
            android:id="@+id/img_fav_logo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_logo_circle"
            android:padding="6dp"
            android:contentDescription="Logo coffee shop" />

        <!-- Tombol Hapus Favorit -->
        <ImageView
            android:id="@+id/btn_remove_favorite"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_favorite"
            android:tint="#E53935"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Hapus dari favorit"
            android:padding="6dp"/>

        <!-- Info Coffee Shop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/img_fav_logo"
            android:layout_toStartOf="@id/btn_remove_favorite"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingEnd="8dp">

            <!-- Nama -->
            <TextView
                android:id="@+id/tv_fav_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coffee Shop"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Rating -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_star"
                    android:tint="@color/brown"
                    android:contentDescription="Rating" />

                <TextView
                    android:id="@+id/tv_fav_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 4.8"
                    android:textColor="@color/brown"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginStart="2dp" />
            </LinearLayout>

            <!-- Alamat -->
            <TextView
                android:id="@+id/tv_fav_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jakarta"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="3dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Harga -->
            <TextView
                android:id="@+id/tv_fav_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 15k - 35k"
                android:textColor="@color/light_brown"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
